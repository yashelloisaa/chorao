.hero{
  height: 70vh;
  background:
    linear-gradient(
      rgba(0,0,0,.55),
      rgba(0,0,0,.75)
    ),
    url('imagens/chorao-topo.jpg');

  background-size: cover;
  background-position: center 70%;
  background-repeat: no-repeat;

  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center
}
